# .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
.venv/
ENV/

# Environment Variables & Secrets (CRITICAL)
.env
.env.test
.env.production
.flaskenv
secrets.py

# Local Storage / Databases
# We ignore these because they are generated per-instance
# and contain business-specific data.
chatbot_config.json
workflow.json
*.log
*.sqlite

# IDEs & Editors
.vscode/
.idea/
*.swp
*.swo
.project
.pydevproject
.settings/

# OS Related
.DS_Store
Thumbs.db
desktop.ini

# Deployment
.render/
Procfile.local